# API URL
# In production, this should be your backend URL (e.g., https://careerx-api.railway.app)
NEXT_PUBLIC_API_BASE_URL="http://localhost:5000"
NEXT_PUBLIC_API_VERSION="v1"

# Clerk Configuration (Frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Cashfree Configuration
# Use 'sandbox' for testing or 'production' for live payments
NEXT_PUBLIC_CASHFREE_ENV="sandbox"
NEXT_PUBLIC_ENABLE_PAYMENTS="true"

# Website URL
# Use your actual deployed domain here
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Feature Toggles
NEXT_PUBLIC_SHOW_TESTIMONIALS="true"
NEXT_PUBLIC_SHOW_JOB_ALERTS="true"
